generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  watchlist Watchlist[]
  portfolio Portfolio[]
}

model Watchlist {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  symbol String
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  buyPrice  Float

  @@unique([userId, symbol])
}

model Portfolio {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  symbol    String
  quantity  Float
  buyPrice  Float
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
